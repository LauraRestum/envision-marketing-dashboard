# Firebase (client-side config, safe in browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Server-side only (Vercel env variables, never in browser)
ANTHROPIC_API_KEY=
FIREBASE_SERVICE_ACCOUNT=
CLICKUP_API_TOKEN=
META_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
RESEND_API_KEY=
RESEND_FROM_ADDRESS=marketing@envisionus.com
# Client-side password hash (SHA-256, safe to expose in browser)
# Generate with: echo -n "yourpassword" | sha256sum
VITE_DASHBOARD_PASSWORD_HASH=
EXTERNAL_HUB_URL=https://envision-marketing-brandhub.vercel.app
